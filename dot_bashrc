#
# ~/.bashrc
#

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# don't put duplicate lines or lines starting with space in the history.
HISTCONTROL=ignoreboth

# append to the history file, don't overwrite it
shopt -s histappend

# for setting history length see HISTSIZE and HISTFILESIZE in bash(1)
HISTSIZE=10000
HISTFILESIZE=20000

# check the window size after each command and, if necessary, update the values of LINES and COLUMNS.
shopt -s checkwinsize

# Use starship
eval "$(starship init bash)"

alias ls='ls --color=auto'
alias list='ls -AFoqvh --time-style long-iso --group-directories-first'
alias listsize='list -S'
alias listtime='ls -AFoqvh --time-style long-iso -t -1'
alias mnt='mount | column -t | egrep ^/dev/ | sort'
alias cpv='rsync -ah --inplace --no-whole-file --info=progress2 '
alias rmv='mv --force -t ~/.local/share/Trash '

# Custom bash prompt
export PS1="\[\e[1;32m\]\u\[\e[m\]: \[\033[1;34m\]\w\[\033[00m\] \$ "

alias pacdiff='DIFFPROG=meld pacdiff --sudo --backup'
alias checkservices='DIFFPROG=nano checkservices'

# Pkgfile database to be checked for missing commands
source /usr/share/doc/pkgfile/command-not-found.bash

# Bash completion for sudo
complete -cf sudo

# Interactive fzf enhancements
# ctrl-r lists command history
# ctrl-t lists files and folders
# alt-c offers a visual cd
# Other uses: $ kill -9 <TAB>
alias fzfp="fzf --ansi --preview '(highlight -O ansi {} 2>/dev/null || cat {} || tree -C {}) 2>/dev/null | head -200'"
eval "$(fzf --bash)"

# Work around a loop due to Steam pointing back to root and remove the large amounts of files in .cache
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .steam --exclude .local\/share\/Steam --exclude .cache --exclude Disk2/Steam --exclude Disk2/Steam_Library --exclude Disk2/Virtualbox'

export FZF_CTRL_R_OPTS="
  --bind 'ctrl-y:execute-silent(echo -n {2..} | pbcopy)+abort'
  --color header:italic
  --header 'Press CTRL-Y to copy command into clipboard'"

export FZF_CTRL_T_OPTS="
  --walker-skip .git,node_modules,target
  --preview 'bat -n --color=always {}'
  --bind 'ctrl-/:change-preview-window(down|hidden|)'"

export FZF_ALT_C_OPTS="
  -i
  --walker-skip .git,node_modules,target
  --preview 'tree -C {}'"

export FZF_DEFAULT_OPTS=" \
--color=bg+:#313244,bg:#1E1E2E,spinner:#F5E0DC,hl:#F38BA8 \
--color=fg:#CDD6F4,header:#F38BA8,info:#CBA6F7,pointer:#F5E0DC \
--color=marker:#B4BEFE,fg+:#CDD6F4,prompt:#CBA6F7,hl+:#F38BA8 \
--color=selected-bg:#45475A \
--color=border:#6C7086,label:#CDD6F4"

_fzf_compgen_path() {
  fd --hidden --follow --exclude ".steam" --exclude ".local/share/Steam" . "$1"
}

_fzf_compgen_dir() {
  fd --type d --hidden --follow --exclude ".steam" --exclude ".local/share/Steam" . "$1"
}

alias pacinstall="pacman -Slq | fzf --multi --preview 'pacman -Si {1}' | xargs -ro sudo pacman -S"
alias pacremove="pacman -Qq | fzf --multi --preview 'pacman -Qi {1}' | xargs -ro sudo pacman -Rncs"

# Make pipx programs executable
export PATH="$PATH:/home/till/.local/bin"

# Make sure chezmoi and other tools default to nano not vim
export EDITOR="nano"

# Have an easier command for editing dotfiles with chezmoi
alias dotedit='chezmoi edit --apply'

export SHELLHELP="\n
‎┌────────────────────────────────────────────────────────────────\n
   Ctrl-R \t	Interactive command history \n
   Ctrl-T \t	Interactive file and folder list \n
   Alt-C \t	Interactive cd \n
├────────────────────────────────────────────────────────────────\n
   list \t	Expanded ls \n
   listsize \t	List by size \n
   listtime \t	List by time \n
   mnt \t\t	List mounted drives \n
   cpv \t\t	Enhanced copy command \n
   rmv \t\t	Move to trash instead of delete \n
   dotedit \t	Edit dotfiles managed by Chezmoi \n	
   pacinstall \t	Interactive package installation \n
   pacremove \t	Interactive package removal \n
   pacdiff \t	Start editor to review pacman config changes \n
   checkservices Check for systemd and other install/remove cruft \n
└────────────────────────────────────────────────────────────────
"
alias shellhelp='echo -e "$SHELLHELP"'

# Execute with the start of the interactive shell
fastfetch --logo none
shellhelp

