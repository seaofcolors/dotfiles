dwindle {
    preserve_split = true # You probably want this
}

master {
    new_status = master
}

windowrule {
    # Ignore maximize requests from all apps. You'll probably like this.
    name = suppress-maximize-events
    match:class = .*
    suppress_event = maximize
}

windowrule {
    # Fix some dragging issues with XWayland
    name = fix-xwayland-drags
    match:class = ^$
    match:title = ^$
    match:xwayland = true
    match:float = true
    match:fullscreen = false
    match:pin = false
    no_focus = true
}

windowrule {
    # Hyprland-run windowrule
    name = move-hyprland-run
    match:class = hyprland-run
    move = 20 monitor_h-120
    float = yes
}

windowrule {
    name = make-feh-fullscreen
    match:class = feh
    border_size = 0
    fullscreen = on
}

windowrule {
    # Make Freetube's PIP popup window float and pin it to all workspaces
    name = float-and-pin-freetube
    match:title = Picture in picture
    float = on
    pin = on
}

windowrule {
    # Make Youtube's PIP popup window float and pin it to all workspaces
    name = float-and-pin-youtube
    match:title = Picture-in-Picture
    float = on
    pin = on
    size = 600 400
    move = (((monitor_w)-(window_w))-3) (((monitor_h)-(window_h))-3)
}
