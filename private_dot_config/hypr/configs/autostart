# Log startup
exec-once = ~/.config/hypr/scripts/hypr-startup-log.sh

# ML4W starts listeners - check them out and maybe build similar listeners
# exec-once = ~/.config/ml4w/listeners.sh --startall

# Start Polkit and update dbus
exec-once = systemctl --user import-environment XDG_CURRENT_DESKTOP XDG_SESSION_TYPE
exec-once = dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP

exec-once = /usr/lib/xdg-desktop-portal-hyprland

exec-once = systemctl --user start hyprpolkitagent
exec-once = ~/.config/hypr/scripts/xdg-fix.sh &

# Fix the desktop portal issues
exec-once = /usr/lib/xdg-desktop-portal --replace

exec-once = /usr/lib/polkit-gnome/polkit-gnome-authentication-agent-1

exec-once = hyprctl setcursor catppuccin-mocha-dark-cursors 28

exec-once = cursor-clip --daemon

exec-once = ~/.config/hypr/scripts/waybar-launch.sh &
exec-once = wait 1; ~/.config/hypr/scripts/waybar-launch.sh &
exec-once = wait 5; ~/.config/hypr/scripts/waybar-launch.sh &
exec-once = wait 10; ~/.config/hypr/scripts/waybar-fix.sh &

exec-once = dunst
exec-once = hypridle
exec-once = udiskie --appindicator
exec-once = nm-applet
exec-once = blueman-applet
exec-once = awww-daemon
exec-once = awww img ~/.config/backgrounds/arch-rainbow-catppuccin-mocha-2.png &
exec-once = wait 1; awww img ~/.config/backgrounds/arch-rainbow-catppuccin-mocha-2.png &

exec-once = ~/.config/hypr/scripts/hypermoncfgd-fix.sh &

exec-once = [workspace 1 silent] wait 10; QT_QPA_PLATFORM=xcb insync start
exec-once = [workspace 1 silent] ~/.config/hypr/scripts/insync-fix.sh

exec-once = [workspace 10 silent] feh -x -F ~/.config/backgrounds/hyprland-keybindings.jpg

